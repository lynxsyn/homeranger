{
  "name": "homeranger",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@10.34.1",
  "engines": {
    "node": ">=22.16.0",
    "pnpm": ">=10.34.1"
  },
  "scripts": {
    "lint": "eslint . --max-warnings=0",
    "build": "pnpm --filter @homeranger/shared build && pnpm --filter @homeranger/backend-core build && pnpm --filter @homeranger/api build && pnpm --filter @homeranger/processor build && pnpm --filter @homeranger/scheduler build && pnpm --filter @homeranger/web build",
    "typecheck": "pnpm -r --parallel run typecheck",
    "test": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:all": "vitest run",
    "test:coverage": "vitest run --project unit --coverage",
    "test:e2e": "playwright test",
    "test:e2e:local": "E2E_BASE_URL=http://localhost:5173 playwright test",
    "dev": "bash scripts/dev.sh",
    "dev:services": "docker compose -f docker-compose.dev.yaml up -d --wait",
    "dev:api": "pnpm --filter @homeranger/api dev",
    "dev:worker": "pnpm --filter @homeranger/processor dev",
    "dev:scheduler": "pnpm --filter @homeranger/scheduler dev",
    "dev:web": "pnpm --filter @homeranger/web dev",
    "smoke:read": "tsx scripts/email-smoke-read.ts",
    "smoke:inspect": "tsx scripts/email-smoke-inspect.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "browser-tabs-lock",
      "msgpackr-extract"
    ]
  },
  "devDependencies": {
    "@homeranger/backend-core": "workspace:*",
    "@playwright/test": "1.60.0",
    "@types/mailparser": "^3.4.6",
    "@types/node": "25.6.2",
    "@typescript-eslint/eslint-plugin": "8.60.0",
    "@typescript-eslint/parser": "8.60.0",
    "@vitest/coverage-v8": "4.1.7",
    "concurrently": "^9.2.1",
    "eslint": "10.3.0",
    "imapflow": "^1.3.5",
    "jiti": "2.7.0",
    "mailparser": "^3.9.9",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.60.0",
    "vitest": "4.1.7"
  }
}
