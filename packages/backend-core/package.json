{
  "name": "@homeranger/backend-core",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "sh -c 'cd ../.. && if [ \"$1\" = \"--\" ]; then shift; fi; npx vitest run --project unit \"$@\"' --"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.94.0",
    "@aws-sdk/client-s3": "3.1058.0",
    "@fastify/cors": "11.2.0",
    "@fastify/formbody": "8.0.2",
    "@homeranger/shared": "workspace:*",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@trpc/server": "11.16.0",
    "bullmq": "5.77.6",
    "dotenv": "17.4.2",
    "fastify": "5.8.5",
    "ioredis": "5.10.1",
    "jose": "4.15.9",
    "nodemailer": "8.0.10",
    "pg": "8.20.0",
    "prom-client": "15.1.3",
    "resend": "6.12.4",
    "superjson": "2.2.6",
    "unpdf": "1.6.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.6.2",
    "@types/nodemailer": "8.0.0",
    "@types/pg": "8.20.0",
    "typescript": "5.9.3",
    "vitest": "4.1.7"
  }
}
