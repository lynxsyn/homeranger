# .aide/project.env — homeranger project configuration
# Shell-sourceable. Sourced by release-tag-policy.sh, post-release-verify.sh,
# and (when adopted) sync-claude-runtime.sh / verify-claude-runtime.sh.
# See aide/docs/consumption.md for the full variable contract.
#
# Phase A5: homeranger tenant migrated to the Horizon platform cluster.
# The Kustomization CR lives in horizon-infra/clusters/platform/tenants/homeranger/.
# VERIFY_* vars below now target the platform cluster (as of A5).

# ── Project identity ──────────────────────────────────────────────────────────
AIDE_PROJECT=homeranger

# ── Release tagging ───────────────────────────────────────────────────────────
# homeranger is pre-1.0 greenfield; current latest tag is v0.45.2 so the seed
# is irrelevant (tags already exist), but kept explicit for documentation.
TAG_SEED=v0.0.0

# ── Post-release verify (platform cluster as of A5) ──────────────────────────
# Default mode is app — homeranger is M2+ (api deployment exists).
# Override to VERIFY_MODE=infra during infra-only releases.
VERIFY_MODE=app

# Kubernetes namespace (platform cluster)
VERIFY_NAMESPACE=homeranger

# App-mode deployment name (the Fastify/tRPC API)
VERIFY_DEPLOYMENT=homeranger-api

# Flux Kustomization name — matches the CR in horizon-infra tenants/homeranger/
VERIFY_FLUX_KS=homeranger

# Flux namespace (flux-system on the platform cluster)
VERIFY_FLUX_NS=flux-system

# External base URL for HTTP probes (app mode).
# When set, curl probes through the public edge (Cloudflare Tunnel); when unset,
# in-cluster kubectl exec wget is used. CF Access service tokens are passed as
# CF_ACCESS_CLIENT_ID / CF_ACCESS_CLIENT_SECRET on the command line (not here —
# they are secrets, not config).
# Example: VERIFY_API_BASE_URL=https://homeranger.app
VERIFY_API_BASE_URL=

# Seconds to wait per verification gate (default 600 = 10 min)
VERIFY_TIMEOUT_SEC=600

# Platform cluster as of A5 — tenant is provisioned and reconciled.
VERIFY_TARGET_PROVISIONED=true
