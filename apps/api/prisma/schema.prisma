// homeranger data model ‚Äî multi-user via Supabase Auth identity (the verified
// JWT `sub` is the owner key). Per-user data is scoped by a nullable `userId`
// column: `userId IS NULL` is the OPERATOR / default namespace (the legacy
// single-user rows + everything the backend automation engine reads), while
// every authenticated non-operator user gets their own `userId` namespace.
// There is still NO Postgres RLS ‚Äî ownership is enforced in the repository
// layer by the resolved owner key (ownerKeyFor(ctx.user)); Supabase is used for
// AUTHENTICATION only, the data stays in this self-hosted pgvector Postgres.
// Conventions mirror Doxus control-plane-api/prisma/schema.prisma exactly:
//   ‚Ä¢ id String @id @default(uuid(7)) @db.Uuid
//   ‚Ä¢ timestamps @db.Timestamptz(6)
//   ‚Ä¢ top-level PascalCase enums with snake_case values
//   ‚Ä¢ prices as integer pence (never floating point)
// Prisma 7 + @prisma/adapter-pg (driver adapter): the datasource block carries
// no `url`; the connection string is supplied at runtime via PrismaPg
// (packages/backend-core/src/lib/prisma.ts) and at migrate-time via
// prisma.config.ts (`datasource: { url: env("MIGRATION_DATABASE_URL") }`).
// The pgvector `embedding` columns are declared as Unsupported("vector(1024)")
// ‚Äî Prisma has no native vector type, so reads/writes go through raw SQL
// ($queryRaw / $executeRaw). The column + HNSW index are created by a raw
// migration, NOT by Prisma's diff engine.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ Enums ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

enum Tenure {
  freehold
  leasehold
  share_of_freehold
  commonhold
  unknown
}

// Value order is kept byte-for-byte identical to PropertyTypeEnum in
// packages/shared/src/listing-enums.ts; the backend-core drift test asserts it.
enum PropertyType {
  detached
  semi_detached
  terraced
  flat
  maisonette
  bungalow
  cottage
  land
  other
  unknown
}

enum EpcRating {
  a
  b
  c
  d
  e
  f
  g
  unknown
}

// LOCKED by docs/plans/homeranger-plan.md:86 ‚Äî these five values are canonical.
// Mirrors ListingStatusEnum in packages/shared/src/listing-enums.ts exactly.
enum ListingStatus {
  pre_market
  live
  under_offer
  sold
  withdrawn
}

// Listing.primarySource + ListingSourceRecord.sourceType.
// No compliant-API channel ‚Äî agent_email | manual only (no licenceClass).
enum ListingSource {
  agent_email
  manual
}

// Email SPF/DKIM verdicts ‚Äî reuses the Doxus EmailAuthVerdict enum shape.
enum EmailAuthVerdict {
  pass
  fail
  softfail
  neutral
  none
  temperror
  permerror
  unknown
}

// Inbound/outbound direction for an outreach message.
enum MessageDirection {
  inbound
  outbound
}

// OutreachThread lifecycle (M6). A guarded state machine ‚Äî see
// OutreachRepository.advanceStatus, which rejects illegal transitions:
//   active        ‚Üí awaiting_reply  (first outbound send)
//   awaiting_reply ‚Üí replied        (a listing-bearing inbound reply arrives)
//   awaiting_reply ‚Üí awaiting_reply (a follow-up send; idempotent)
//   replied        ‚Üí awaiting_reply (a follow-up after a reply)
//   (any)          ‚Üí closed         (agent opt-out / unsubscribe / suppression)
// `closed` is terminal: no further sends or transitions out of it.
enum OutreachThreadStatus {
  active
  awaiting_reply
  replied
  closed
}

// Whether the agent's mailbox is a paid corporate portal subscriber, an
// individual mailbox, or not yet classified.
enum MailboxType {
  corporate_subscriber
  individual
  unknown
}

// Suppression reasons ‚Äî never email an address carrying any of these.
enum SuppressionReason {
  unsubscribe
  hard_bounce
  spam_complaint
  manual
}

// Provider delivery-event feed (Resend webhook event types, normalised).
enum EmailEventType {
  delivered
  bounced
  complained
  opened
  clicked
  deferred
  failed
}

// Search lifecycle. `active` searches reach out + pull in homes; `paused` quietly
// stops both with NO "we've stopped" message (relationship-safe). No terminal
// state ‚Äî a search toggles freely between the two.
enum SearchStatus {
  active
  paused
}

// ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ Models ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

// The canonical de-duplicated property. `addressNormalized` is the dedup key:
// re-ingesting the same property from multiple agent emails updates the same
// row. `embedding` is the Voyage voyage-3.5 vector(1024); it is declared
// Unsupported because Prisma has no vector type ‚Äî it is written/read via raw
// SQL and ranked by the HNSW vector_cosine_ops index created in the raw
// migration.
model Listing {
  id                String                       @id @default(uuid(7)) @db.Uuid
  addressNormalized String                       @unique
  addressRaw        String?
  postcode          String?
  outcode           String?
  pricePence        Int?
  bedrooms          Int?
  bathrooms         Int?
  tenure            Tenure?
  propertyType      PropertyType?
  epcRating         EpcRating?
  listingStatus     ListingStatus                @default(pre_market)
  isPreMarket       Boolean                      @default(false)
  listingUrl        String?
  primarySource     ListingSource                @default(agent_email)
  agentEmail        String?
  agencyName        String?
  embedding         Unsupported("vector(1024)")?
  firstSeenAt       DateTime                     @default(now()) @db.Timestamptz(6)
  lastSeenAt        DateTime                     @default(now()) @db.Timestamptz(6)
  createdAt         DateTime                     @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime                     @updatedAt @db.Timestamptz(6)

  sourceRecords ListingSourceRecord[]
  photoAnalyses PhotoAnalysis[]
  scores        ListingScore[]
  savedBy       SavedListing[]
  dismissedBy   DismissedListing[]

  @@index([outcode])
  @@index([postcode])
  @@index([listingStatus, lastSeenAt(sort: Desc)])
  @@index([pricePence])
}

// Provenance for every place a Listing was observed. `@@unique([sourceType,
// externalId])` makes re-ingest idempotent ‚Äî the second upsert of the same
// (sourceType, externalId) updates the existing row rather than creating a
// duplicate. No `licenceClass` (the compliant-API channel was removed).
model ListingSourceRecord {
  id         String        @id @default(uuid(7)) @db.Uuid
  listingId  String        @db.Uuid
  listing    Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  sourceType ListingSource
  externalId String
  sourceUrl  String?
  rawPayload Json?
  observedAt DateTime      @default(now()) @db.Timestamptz(6)
  createdAt  DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime      @updatedAt @db.Timestamptz(6)

  @@unique([sourceType, externalId])
  @@index([listingId])
}

// Vision-model taste analysis of a listing photo. Deduped by `imageHash` so the
// same image is never re-analysed (and re-billed). `costPence` tracks spend.
model PhotoAnalysis {
  id           String   @id @default(uuid(7)) @db.Uuid
  listingId    String   @db.Uuid
  listing      Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  imageHash    String   @unique
  imageUrl     String?
  tasteScore   Int?
  featuresJson Json     @default("{}")
  model        String
  costPence    Int      @default(0)
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)

  @@index([listingId])
}

// Combined relevance score for a Listing against the SearchProfile.
// `vectorScore` is cosine similarity; `llmScore` is the optional LLM re-rank;
// `combinedScore` is the blended value used for ordering; `rationale` is the
// human-readable explanation.
model ListingScore {
  id            String   @id @default(uuid(7)) @db.Uuid
  listingId     String   @db.Uuid
  listing       Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  vectorScore   Float
  llmScore      Float?
  combinedScore Float
  rationale     String?
  scoredAt      DateTime @default(now()) @db.Timestamptz(6)
  createdAt     DateTime @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @db.Timestamptz(6)

  @@unique([listingId])
  @@index([combinedScore(sort: Desc)])
}

// Single-row search profile (single-user product). `preferenceEmbedding` is the
// Voyage vector(1024) of `freeTextPreferences`, used as the query vector for
// listingRepository.vectorTopK. Declared Unsupported (raw SQL read/write).
model SearchProfile {
  id                  String                       @id @default(uuid(7)) @db.Uuid
  // Owner key. NULL = the operator/default profile (the legacy singleton row +
  // what the outreach + AI-matching engine reads). A non-operator authenticated
  // user gets their own row keyed by their Supabase user id. Unique so each
  // owner has exactly one profile (the NULL singleton is unique by its fixed id).
  userId              String?                      @unique @db.Uuid
  freeTextPreferences String                       @default("")
  minBedrooms         Int?
  maxPricePence       Int?
  outcodes            String[]                     @default([])
  requiredTenure      Tenure?
  // Buyer identity (the operator's own details) ‚Äî used to sign + pace outreach
  // emails. firstName/lastName form the sign-off name (falls back to the
  // RESEND_FROM display name when blank); phone is appended when set; urgency
  // (browsing|active|ready|soon) selects the closing "how soon" line.
  firstName           String                       @default("")
  lastName            String                       @default("")
  phone               String                       @default("")
  urgency             String                       @default("active")
  preferenceEmbedding Unsupported("vector(1024)")?
  createdAt           DateTime                     @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime                     @updatedAt @db.Timestamptz(6)
}

// An estate agent (or branch) we may contact. `email` is unique. `optedOut`
// short-circuits all outreach. `coveredOutcodes` records the geography the
// agent operates in. A uuid surrogate `id` is the PK (`email` is unique) so the
// repository keys threads/contacted-state on a stable id, not the mutable email.
model Agent {
  id              String      @id @default(uuid(7)) @db.Uuid
  email           String      @unique
  agencyName      String?
  contactName     String?
  mailboxType     MailboxType @default(unknown)
  optedOut        Boolean     @default(false)
  coveredOutcodes String[]    @default([])
  lastContactedAt DateTime?   @db.Timestamptz(6)
  createdAt       DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime    @updatedAt @db.Timestamptz(6)

  threads OutreachThread[]

  @@index([optedOut])
}

// A conversation with a single agent. The thread groups inbound + outbound
// messages and tracks the last activity for follow-up scheduling.
model OutreachThread {
  id            String               @id @default(uuid(7)) @db.Uuid
  agentId       String               @db.Uuid
  agent         Agent                @relation(fields: [agentId], references: [id], onDelete: Cascade)
  subject       String?
  status        OutreachThreadStatus @default(active)
  lastMessageAt DateTime?            @db.Timestamptz(6)
  createdAt     DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime             @updatedAt @db.Timestamptz(6)

  messages OutreachMessage[]

  @@index([agentId])
  @@index([lastMessageAt(sort: Desc)])
  // Follow-up scan: threads awaiting a reply, oldest activity first.
  @@index([status, lastMessageAt(sort: Desc)])
}

// A single email in a thread. Inbound messages carry parsed SPF/DKIM verdicts
// and `parsedListingIds` (listings extracted from the reply). `providerMessageId`
// is unique so a redelivered webhook is idempotent.
model OutreachMessage {
  id                String           @id @default(uuid(7)) @db.Uuid
  threadId          String           @db.Uuid
  thread            OutreachThread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  direction         MessageDirection
  providerMessageId String
  fromEmail         String
  toEmail           String
  subject           String?
  bodyText          String?
  bodyHtml          String?
  spfVerdict        EmailAuthVerdict @default(unknown)
  dkimVerdict       EmailAuthVerdict @default(unknown)
  parsedListingIds  String[]         @default([]) @db.Uuid
  sentAt            DateTime?        @db.Timestamptz(6)
  receivedAt        DateTime?        @db.Timestamptz(6)
  createdAt         DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime         @updatedAt @db.Timestamptz(6)

  @@unique([providerMessageId])
  @@index([threadId])
}

// Global do-not-contact list. Any email present here is suppressed regardless of
// Agent.optedOut. Reasons mirror the standard email-suppression taxonomy.
model SuppressionEntry {
  id        String            @id @default(uuid(7)) @db.Uuid
  email     String
  reason    SuppressionReason
  note      String?
  createdAt DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt DateTime          @updatedAt @db.Timestamptz(6)

  @@unique([email, reason])
  @@index([email])
}

// Raw provider delivery/bounce/complaint feed (Resend webhooks, normalised).
// `providerEventId` is unique so a redelivered webhook is idempotent. This is
// the source feed that drives SuppressionEntry insertion.
model EmailEvent {
  id              String         @id @default(uuid(7)) @db.Uuid
  providerEventId String         @unique
  messageId       String?
  email           String
  eventType       EmailEventType
  payload         Json           @default("{}")
  occurredAt      DateTime       @default(now()) @db.Timestamptz(6)
  createdAt       DateTime       @default(now()) @db.Timestamptz(6)

  @@index([email])
  @@index([eventType, occurredAt(sort: Desc)])
}

// Single-row email warm-up + send-governance state ‚Äî ramps the per-day send
// cap so a new sending domain builds reputation gradually rather than blasting
// from day one, and carries the manual kill-switch (M6 AC#6). `killSwitch=true`
// halts ALL outbound sends immediately (ComplianceGuard gate 5), independent of
// the cap; surfaced + toggled by the M7 dashboard.
model WarmupState {
  id            String   @id @default(uuid(7)) @db.Uuid
  dailyCap      Int      @default(20)
  sentToday     Int      @default(0)
  windowDate    DateTime @db.Date
  killSwitch    Boolean  @default(false)
  rampStartedAt DateTime @default(now()) @db.Timestamptz(6)
  createdAt     DateTime @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @db.Timestamptz(6)
}

// A "search" ‚Äî a standing brief the operator runs to work an area. It carries
// WHERE to look (free-text `location` ‚Üí resolved `outcodes`), WHAT kind of home
// (`types`/`condition`/`land`/`saleMethods` + beds/price), and the free-text
// `keywords` taste that shapes the first outreach email. These settings are
// scaffolding for a strong first email, NOT rigid filters. A search relates to
// listings purely by OUTCODE ‚Äî the "homes found" link-through filters Listings
// to `outcodes`; agent/thread linkage + launch arrive in a later milestone.
// Multi-row, unlike the single-row SearchProfile (which this supersedes in the
// UI). The string-array option fields hold the design's display labels (e.g.
// "Restoration project", "Auction"), validated against the shared option sets at
// the wire boundary.
model Search {
  id            String      @id @default(uuid(7)) @db.Uuid
  // Owner key. NULL = the operator's searches (the legacy single-user rows); a
  // non-operator authenticated user's searches carry their Supabase user id.
  userId        String?     @db.Uuid
  name          String
  location      String      @default("")
  outcodes      String[]    @default([])
  types         String[]    @default([])
  condition     String[]    @default([])
  land          String[]    @default([])
  saleMethods   String[]    @default([])
  minBedrooms   Int?
  maxPricePence Int?
  keywords      String      @default("")
  status        SearchStatus @default(active)
  createdAt     DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime    @updatedAt @db.Timestamptz(6)

  @@index([status])
  @@index([updatedAt(sort: Desc)])
  @@index([userId])
}

// A user's saved ("interested") listing ‚Äî the per-user bookmark that backs the
// listings "Interest" feature. The Listing catalogue itself is GLOBAL + shared
// (de-duplicated across all users); SavedListing is the per-owner overlay that
// records which homes a given user has kept. `userId` follows the same nullable
// owner-key convention as Search/SearchProfile (NULL = operator). Uniqueness of
// (owner, listing) is enforced by a COALESCE-based unique index created in the
// raw migration (Prisma cannot express a NULL-safe expression index), so the
// operator's NULL-namespaced saves are also deduped per listing.
model SavedListing {
  id        String   @id @default(uuid(7)) @db.Uuid
  userId    String?  @db.Uuid
  listingId String   @db.Uuid
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@index([userId])
  @@index([listingId])
}

// A user's dismissed ("hidden") listing ‚Äî the per-user overlay that hides a home
// from the working feed. The exact mirror of SavedListing (same nullable
// owner-key convention, same COALESCE-based NULL-safe unique index in the raw
// migration), but the OPPOSITE intent: a save surfaces a home, a dismiss buries
// it. Dismissing is REVERSIBLE (restore deletes the row) and SILENT ‚Äî it is
// never communicated to the agent; it only tunes the buyer's own feed/scoring.
// The two overlays are INDEPENDENT: a home can be neither, saved, dismissed, or
// (transiently) both ‚Äî the UI computes the Active / Saved / Dismissed buckets
// from the two id sets. The search-removal cascade hides a search's homes by
// inserting DismissedListing rows for the owner (restorable from the Dismissed
// view), never deleting the global Listing rows.
model DismissedListing {
  id        String   @id @default(uuid(7)) @db.Uuid
  userId    String?  @db.Uuid
  listingId String   @db.Uuid
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@index([userId])
  @@index([listingId])
}
