# homescout — UK property aggregator. Home cluster (horizon-lab) + Cloudflare R2/tunnel.
# Auto-loads .env and isolates kubectl context so a stray `kubectl` here can't hit the
# wrong cluster. No GCP/gcloud — homescout deploys via FluxCD, not GKE.
#
# direnv loads this on `cd` into the project (requires `direnv allow` once per machine).

# Auto-load local secrets (ANTHROPIC, VOYAGE, RESEND, R2, Cloudflare).
if [ -f "$PWD/.env" ]; then
  set -a
  . "$PWD/.env"
  set +a
fi

# Isolate kubectl state under the project so it never clobbers another project's context.
export KUBECONFIG=$PWD/.state/kubeconfig

# per-project mem0 store (helper in ~/.config/direnv/direnvrc)
use_mem0
