# TEMPLATE — do NOT commit a real .enc.yaml until the two secrets below are
# created with REAL key material and encrypted via `sops -e -i` using
# homescout's age recipient (see .sops.yaml).
#
# Mirrors doxus-infra/deploy/flux-system/bootstrap-secrets.enc.yaml: the two
# preconditions Flux needs before it can reconcile homescout from git.
#
# 1. Secret/flux-system/homescout-git-deploy-key — the SSH deploy key + the
#    GitHub host known_hosts entry the homescout GitRepository uses to read
#    ssh://git@github.com/lynxsyn/homescout (read-only deploy key).
# 2. Secret/flux-system/sops-age-homescout — homescout's OWN age PRIVATE key,
#    used by the homescout Kustomization to decrypt *.enc.yaml. This is a
#    DIFFERENT key from Doxus's sops-age; Doxus's key must never be placed here.
#
# Recovery source of truth (like Doxus): keep the encrypted backup of these two
# secrets here, EXCLUDED from any kustomization.yaml resources list, applied
# imperatively only during bootstrap / break-glass.
#
# After filling in real values, encrypt the file in place and rename to drop
# the .TEMPLATE suffix:
#   sops -e -i infra/deploy/flux/bootstrap-secrets.enc.yaml
---
apiVersion: v1
kind: Secret
metadata:
  name: homescout-git-deploy-key
  namespace: flux-system
type: Opaque
stringData:
  identity: |
    REPLACE_WITH_DEPLOY_KEY_PRIVATE_OPENSSH
  identity.pub: |
    REPLACE_WITH_DEPLOY_KEY_PUBLIC
  known_hosts: |
    REPLACE_WITH_GITHUB_KNOWN_HOSTS
---
apiVersion: v1
kind: Secret
metadata:
  name: sops-age-homescout
  namespace: flux-system
type: Opaque
stringData:
  age.agekey: |
    REPLACE_WITH_HOMESCOUT_AGE_PRIVATE_KEY
