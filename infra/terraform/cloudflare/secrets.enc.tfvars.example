# Plaintext template for the SOPS-encrypted secrets.enc.tfvars.
#
# This file holds ACCOUNT METADATA ONLY. The live Cloudflare API token is
# NOT stored here — it is injected at apply time from the CLOUDFLARE_API_TOKEN
# GitHub Actions secret (Bitwarden: DOXUS_CF_API_TOKEN). This mirrors Doxus:
# rotating the CF token never leaves Terraform holding stale credentials.
#
# To create the real encrypted file:
#   1. Copy this to secrets.tfvars and fill the real zone_id / account_id
#      (from `.env`: DOXUS_CF_ZONE_ID for aid-engineering.com, DOXUS_CF_ACCOUNT_ID).
#      NOTE: DOXUS_CF_ZONE_ID currently points at doxus.app — you need the
#      ZONE ID for aid-engineering.com specifically. Get it from the Cloudflare
#      dashboard or:
#        curl -s -H "Authorization: Bearer $DOXUS_CF_API_TOKEN" \
#          'https://api.cloudflare.com/client/v4/zones?name=aid-engineering.com' \
#          | jq -r '.result[0].id'
#   2. Encrypt with the homescout age recipient (see .sops.yaml):
#        sops --encrypt secrets.tfvars > secrets.enc.tfvars
#   3. Delete secrets.tfvars (gitignored anyway) and commit secrets.enc.tfvars.
#
# cloudflare_api_token is intentionally absent — CI injects it. For LOCAL
# applies, export CLOUDFLARE_API_TOKEN and add a -var, or temporarily add the
# line here and re-encrypt (never commit the plaintext).

zone_id    = "REPLACE_WITH_AID_ENGINEERING_COM_ZONE_ID"
account_id = "REPLACE_WITH_CF_ACCOUNT_ID"
