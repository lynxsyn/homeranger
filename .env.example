# homeranger environment template — copy to .env and fill in.
# The real .env is gitignored and lives only in the main checkout (direnv sources $PWD/.env).
#
# A full LOCAL loop needs NO paid keys: leave the provider keys blank and turn on
# the FAKE seams at the bottom. Real keys are only needed to exercise real providers.
# Names here are the CANONICAL ones the code reads (process.env.* / import.meta.env.*).

# ── Core infrastructure (required for anything DB/queue-backed) ───────────────
DATABASE_URL="postgresql://homeranger:homeranger@localhost:5432/homeranger"
MIGRATION_DATABASE_URL="postgresql://homeranger_migrator:homeranger@localhost:5432/homeranger"
REDIS_URL="redis://localhost:6379"
# Alternatively REDIS_HOST / REDIS_PORT / REDIS_PASSWORD instead of REDIS_URL.
REDIS_PASSWORD=""

# ── Server runtime ────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT="3000"
HOST="0.0.0.0"
WEB_ORIGIN="http://localhost:5173"     # CORS origin for the SPA (credentials, not wildcard)
# GIT_SHA is injected at build time and surfaced by /api/version (leave unset locally).
METRICS_HOST="0.0.0.0"
METRICS_PORT="9090"

# ── Auth (Supabase) ───────────────────────────────────────────────────────────
# Leave SUPABASE_URL UNSET locally to use the dev auth bypass (operator identity).
# Setting it turns the bypass OFF and requires a real Supabase sign-in.
# In production an unset SUPABASE_URL makes the API refuse to start (fail closed).
SUPABASE_URL=""
SUPABASE_JWT_AUD="authenticated"
OPERATOR_USER_EMAIL="you@example.com"  # the operator → NULL data namespace
# ALLOWED_USER_EMAIL / DEV_USER_EMAIL / DEV_USER_ID are optional dev/legacy fallbacks.

# ── AI: extraction + vision + embeddings ──────────────────────────────────────
ANTHROPIC_API_KEY=""                   # Claude (extraction + Haiku vision). Metered key.
VOYAGE_API_KEY=""                      # Voyage voyage-3.5 embeddings → vector(1024)
# Optional model/cost/tuning knobs have sane defaults; override only if needed, e.g.:
#   EXTRACTION_MODEL VISION_MODEL EMBEDDING_MODEL MATCH_MODEL
#   *_TIMEOUT_MS *_MAX_OUTPUT_TOKENS *_PENCE_PER_MTOK MATCH_TOP_K MATCH_WEIGHT_LLM MATCH_WEIGHT_VECTOR
#   ANALYSIS_KILL_SWITCH ANALYSIS_MONTHLY_BUDGET_PENCE

# ── Email (Resend primary; nodemailer/SMTP fallback) ──────────────────────────
RESEND_API_KEY=""                      # send + inbound-parse + bounce/complaint webhooks
RESEND_FROM=""                         # REQUIRED to actually send (e.g. "HomeRanger <noreply@homeranger.app>")
RESEND_REPLY_TO=""
RESEND_WEBHOOK_SECRET=""               # Svix secret for delivery/bounce/complaint events
RESEND_INBOUND_WEBHOOK_SECRET=""       # Svix secret for the inbound-parse webhook
UNSUBSCRIBE_BASE_URL="http://localhost:3000"
UNSUBSCRIBE_TOKEN_SECRET="changeme-unsubscribe-hmac-secret"   # required (throws in production if unset)
EMAIL_TRANSPORT="resend"               # or "smtp"
SMTP_URL=""                            # only when EMAIL_TRANSPORT=smtp

# ── Storage (Cloudflare R2, for inbound attachments) ──────────────────────────
R2_ENDPOINT=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""

# ── Discovery (Firecrawl) ─────────────────────────────────────────────────────
FIRECRAWL_API_KEY=""                   # leave blank + DISCOVERY_FAKE=1 for local
FIRECRAWL_BASE_URL=""                  # optional override
DISCOVERY_SEARCH_LIMIT=""              # optional

# ── Outreach warm-up + circuit-breaker (defaults are sane; override to tune) ──
# WARMUP_BASE_CAP WARMUP_STEP WARMUP_MAX_CAP WARMUP_WINDOW_SECONDS
# BREAKER_BOUNCE_RATE (0.02) BREAKER_COMPLAINT_RATE (0.001) BREAKER_*_MIN_SAMPLE BREAKER_WINDOW_HOURS
# DOMAIN_COOLDOWN_DAYS (30) OUTREACH_FOLLOWUP_HOURS WARMUP_RECALC_EVERY_MS FOLLOWUP_SCAN_EVERY_MS

# ── Test seams (set =1 to run the whole loop with NO paid APIs) ───────────────
RESEND_FAKE="1"
EXTRACTION_FAKE="1"
ANALYSIS_FAKE="1"
VISION_FAKE="1"
EMBEDDING_FAKE="1"
MATCH_FAKE="1"
DISCOVERY_FAKE="1"
OUTREACH_FAKE="1"

# ── Web (Vite, baked into the SPA bundle — PUBLIC values only) ─────────────────
VITE_SUPABASE_URL=""                   # same project URL as SUPABASE_URL
VITE_SUPABASE_ANON_KEY=""              # publishable anon key (safe to ship in the browser)
